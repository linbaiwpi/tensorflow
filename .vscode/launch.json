{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "preLaunchTask": "benchmark",
            "name": "(gdb) Simple Delegate", 
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bazel-bin/tensorflow/lite/delegates/utils/dummy_delegate/benchmark_model_plus_dummy_delegate",
            "args": [
                "--use_gpu=false",
                "--num_threads=1",
                "--enable_op_profiling=true",
                "--graph=./tflite_models/model_add.tflite",
                "--num_runs=1",
                "--use_dummy_delegate=true",
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb"
        },
    ]
}